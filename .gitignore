# =========================
# 系统文件（Windows）
# =========================
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# =========================
# Obsidian 配置
# =========================

# 忽略整个 .obsidian 目录
.obsidian/*

# 但保留这些（可选同步的配置）
!.obsidian/app.json
!.obsidian/appearance.json
!.obsidian/core-plugins.json
!.obsidian/plugins/

# 如果你不想同步插件，可以加这一行👇
# .obsidian/plugins/

# =========================
# Obsidian 本地状态（强烈建议忽略）
# =========================
.obsidian/workspace.json
.obsidian/graph.json

# =========================
# 临时文件 / 缓存
# =========================
*.log
*.tmp
*.cache

# =========================
# 其他编辑器（防止污染）
# =========================
.vscode/
.idea/